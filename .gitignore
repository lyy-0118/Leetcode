# =========================
# 编译产物 / Compiled Files
# =========================
# Windows 可执行文件
*.exe
*.dll
*.lib
*.pdb

# Linux/macOS 可执行文件
*.out
*.app
*.so
*.dylib

# 编译中间文件 (Object files)
*.o
*.obj
*.d

# =========================
# 常见的构建目录 / Build Directories
# =========================
# Visual Studio / C++ 常用的输出目录
Debug/
Release/
x64/
x86/
bin/
obj/
build/

# CMake 生成的文件 (如果你使用 CMake)
CMakeCache.txt
CMakeFiles/
cmake-build-*/
*.cmake
Makefile

# =========================
# 编辑器与IDE配置 / Editor & IDE Config
# =========================
# VS Code
.vscode/

# Visual Studio
.vs/
*.user
*.suo
*.ipch
*.aps

# CLion (JetBrains)
.idea/

# Xcode
*.xcodeproj/project.xcworkspace/xcuserdata
*.xcuserdatad

# =========================
# 系统文件 / OS Files
# =========================
# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db

# =========================
# 刷题专用 / LeetCode Specific
# =========================
# 本地调试用的输入输出文件
input.txt
output.txt
test.txt
*.log

# 临时代码文件 (以 temp 开头或结尾的文件)
temp.cpp
*temp.cpp
temp*.cpp
